# Copy to .env on the server (never commit real .env)
#   cp .env.production.example .env
# Then set APP_KEY, DB_PASSWORD, MAIL_PASSWORD, GEMINI_API_KEY, etc.

APP_NAME="Disaster Preparedness Training"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://disaster-training.alertaraqc.com
APP_TIMEZONE=Asia/Manila

LOG_CHANNEL=stack
LOG_LEVEL=warning

# Use MySQL/MariaDB on the server (required for Inventory.sql import)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=disaster_training
DB_USERNAME=disaster_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_DOMAIN=.alertaraqc.com
SESSION_SECURE_COOKIE=true

SESSION_TIMEOUT_MINUTES=10
WARNING_BEFORE_LOGOUT_SECONDS=60

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=your-email@gmail.com
MAIL_FROM_NAME="AlerTara QC"

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_VERSION=v1beta

EVALUATION_PASSING_SCORE=75

VITE_APP_NAME="${APP_NAME}"

# Production centralized login (not localhost)
CENTRALIZED_LOGIN_URL=https://login.alertaraqc.com
AUTH_API_ENDPOINT=https://login.alertaraqc.com/api/auth/validate
MAIN_DOMAIN=https://disaster-training.alertaraqc.com

# Campaign Planning System (other group — https://campaign.alertaraqc.com)
# Outbound send: POST /api/v1/campaigns (Training Intelligence)
# Public read:   GET  /api/v1/campaigns/public
GROUP6_INTEGRATION_ENABLED=true
GROUP6_API_BASE_URL=https://campaign.alertaraqc.com
GROUP6_API_KEY=
GROUP6_ENDPOINT_CAMPAIGNS=/api/v1/campaigns
GROUP6_ENDPOINT_CAMPAIGNS_PUBLIC=/api/v1/campaigns/public
# Ask Campaign group for production JWT secret + service user id (sub)
GROUP6_JWT_SECRET=CHANGE_ME_ASK_CAMPAIGN_GROUP
GROUP6_JWT_SUBJECT=1
GROUP6_JWT_ISSUER=public-safety-campaign-system
GROUP6_JWT_AUDIENCE=public-safety-campaign-system
GROUP6_JWT_EXPIRY_SECONDS=86400
# Shared key they use when calling OUR approve/reject API
GROUP6_INBOUND_API_KEY=CHANGE_ME_SHARED_WITH_CAMPAIGN_GROUP
GROUP6_INBOUND_API_HEADER=X-Group6-Api-Key
GROUP6_API_TIMEOUT=30

# CPSQC Patrol — Marshals for Exercise Plan
# Production: https://surveillance.alertaraqc.com
CPSQC_INTEGRATION_ENABLED=false
CPSQC_API_BASE_URL=https://surveillance.alertaraqc.com
CPSQC_API_KEY=
CPSQC_API_TIMEOUT=30
CPSQC_SOURCE_GROUP=group_6
CPSQC_REQUESTING_UNIT="Disaster Preparedness Training and Simulation"
CPSQC_CONTACT_PERSON="LGU Training Admin"
CPSQC_CONTACT_POSITION="Training Coordinator"
CPSQC_CONTACT_NUMBER=09000000000
CPSQC_CONTACT_EMAIL=
